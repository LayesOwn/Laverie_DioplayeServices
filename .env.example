# ============================================================
# DIOLAVERIE — Variables d'environnement (PRODUCTION)
# ============================================================
# Copiez ce fichier en .env et remplissez chaque valeur.
# Ne commitez JAMAIS le fichier .env dans Git.
#
# Generer une SECRET_KEY forte :
#   python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

FLASK_ENV=production

# -- Securite (OBLIGATOIRE) --
SECRET_KEY=REMPLACER_PAR_UNE_CLE_ALEATOIRE_LONGUE

# -- Base de donnees --
# Laisser vide pour utiliser SQLite par defaut (instance/database.db)
# DATABASE_URL=sqlite:///instance/database.db

# -- Compte administrateur (cree au premier demarrage si inexistant) --
ADMIN_DEFAULT_USERNAME=Abdoulaye Diop
ADMIN_DEFAULT_EMAIL=abdoulaye.diop@dioplaye.sn
ADMIN_DEFAULT_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_FORT

# -- Compte invite (acces lecture seule) --
INVITE_DEFAULT_USERNAME=invite
INVITE_DEFAULT_EMAIL=invite@dioplaye.sn
INVITE_DEFAULT_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_FORT
